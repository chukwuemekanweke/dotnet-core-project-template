      "id": 1,
      "options": {
        "content": "## Authentication Failures And Security\nBusiness failure panels in this dashboard are backed by explicit auth failure events.\n\n### Queryable business failure events today\n- `PasswordSignUpFailed`\n- `GoogleSignUpFailed`\n- `EmailConfirmationFailed`\n- `PasswordResetRequestFailed`\n- `PasswordResetCompletionFailed`\n- `SignInFailureProcessed`\n\nSign-in continues to use `SignInFailureProcessed` as the explicit failure signal instead of request-side `...Failed` events.",
        "mode": "markdown"
      },
      "pluginVersion": "12.0.0",
      "title": "Current Failure Event Scope",
      "type": "text"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "value"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({service_name=~\"BackendProjectTemplate.WebAPI|BackendProjectTemplate.Consumer\"} | json | custom_event_name=~\"PasswordSignUpFailed|GoogleSignUpFailed|EmailConfirmationFailed|PasswordResetRequestFailed|PasswordResetCompletionFailed|SignInFailureProcessed\" [$__range]))",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Explicit Auth Failures",
      "type": "stat"
    },
