      "id": 1,
      "options": {
        "content": "## Payments Fulfillment\nThis dashboard focuses on the last-mile business outcome of each payment intent.\n\n### Fulfillment formulas\n- Wallet top-up fulfilled % = `payment.wallet.credited / payment.initiated{payment_intent=\"WalletTopUp\"}`\n- Subscription fulfilled % = `payment.subscription.activated / payment.initiated{payment_intent=\"Subscription\"}`\n- Wallet execution completion % = `payment.wallet.credited / payment.credit_wallet`\n- Subscription execution completion % = `payment.subscription.activated / payment.activate_subscription`",
        "mode": "markdown"
      },
      "pluginVersion": "12.0.0",
      "title": "Fulfillment Scope",
      "type": "text"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "editorMode": "code",
          "expr": "100 * sum(count_over_time({service_name=\"BackendProjectTemplate.Consumer\"} | json | custom_event_name=\"payment.wallet.credited\" [$__range])) / sum(count_over_time({service_name=\"BackendProjectTemplate.WebAPI\"} | json | custom_event_name=\"payment.initiated\" | payment_intent=\"WalletTopUp\" [$__range]))",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Wallet Top-Up Fulfilled %",
      "type": "stat"
    },
