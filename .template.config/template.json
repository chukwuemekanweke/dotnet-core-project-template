{
  "$schema": "http://json.schemastore.org/template",
  "author": "OpenAI",
  "classifications": [
    "Web",
    "API",
    "Backend",
    "Vertical Slice",
    "Clean Architecture"
  ],
  "identity": "BackendProjectTemplate.Template",
  "name": "Backend Project Template",
  "shortName": "backend-template",
  "preferNameDirectory": true,
  "primaryOutputs": [
    {
      "path": "BackendProjectTemplate.slnx"
    }
  ],
  "symbols": {
    "organizationName": {
      "type": "parameter",
      "dataType": "string",
      "defaultValue": "CN",
      "description": "Organization abbreviation or initialism, for example CN"
    },
    "clientName": {
      "type": "parameter",
      "dataType": "string",
      "isRequired": true,
      "description": "Client name segment used in the root namespace and project names"
    },
    "clientProjectName": {
      "type": "parameter",
      "dataType": "string",
      "isRequired": true,
      "description": "Client project name segment used in the root namespace and project names"
    },
    "projectRootName": {
      "type": "generated",
      "generator": "join",
      "replaces": "BackendProjectTemplate",
      "fileRename": "BackendProjectTemplate",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "organizationName"
          },
          {
            "type": "ref",
            "value": "clientName"
          },
          {
            "type": "ref",
            "value": "clientProjectName"
          }
        ],
        "separator": ".",
        "removeEmptyValues": true
      }
    }
  },
  "sources": [
    {
      "exclude": [
        ".vs/**/*",
        ".dotnet/**/*",
        "scripts/**/*",
        "**/bin/**/*",
        "**/obj/**/*",
        "**/*.user",
        "**/*.suo"
      ]
    }
  ]
}
