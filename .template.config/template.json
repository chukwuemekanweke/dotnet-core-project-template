{
  "$schema": "http://json.schemastore.org/template",
  "author": "OpenAI",
  "classifications": [
    "Web",
    "API",
    "Backend",
    "Vertical Slice",
    "Clean Architecture"
  ],
  "identity": "BackendProjectTemplate.Template",
  "name": "Backend Project Template",
  "shortName": "backend-template",
  "sourceName": "BackendProjectTemplate",
  "preferNameDirectory": true,
  "primaryOutputs": [
    {
      "path": "BackendProjectTemplate.slnx"
    }
  ],
  "forms": {
    "lowerCase": {
      "identifier": "lowerCase"
    },
    "dotsToDashes": {
      "identifier": "replace",
      "pattern": "\\.",
      "replacement": "-"
    },
    "dotsToNothing": {
      "identifier": "replace",
      "pattern": "\\.",
      "replacement": ""
    }
  },
  "symbols": {
    "organizationAbbreviation": {
      "type": "parameter",
      "dataType": "string",
      "defaultValue": "CN",
      "description": "Organization abbreviation or initialism, maximum 3 characters, for example CN"
    },
    "clientName": {
      "type": "parameter",
      "dataType": "string",
      "isRequired": true,
      "description": "Client name segment used in the root namespace and project names"
    },
    "clientProjectName": {
      "type": "parameter",
      "dataType": "string",
      "isRequired": true,
      "description": "Client project name segment used in the root namespace and project names"
    },
    "projectRootName": {
      "type": "generated",
      "generator": "join",
      "replaces": "BackendProjectTemplate",
      "fileRename": "BackendProjectTemplate",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "organizationAbbreviation"
          },
          {
            "type": "ref",
            "value": "clientName"
          },
          {
            "type": "ref",
            "value": "clientProjectName"
          }
        ],
        "separator": ".",
        "removeEmptyValues": true
      }
    },
    "projectRootNameLowerCase": {
      "type": "derived",
      "valueSource": "projectRootName",
      "valueTransform": "lowerCase"
    },
    "projectRootNameKebabCase": {
      "type": "derived",
      "valueSource": "projectRootNameLowerCase",
      "valueTransform": "dotsToDashes"
    },
    "projectRootNameCompactLowerCase": {
      "type": "derived",
      "valueSource": "projectRootNameLowerCase",
      "valueTransform": "dotsToNothing",
      "replaces": "backendprojecttemplate"
    },
    "webApiMetricsJobName": {
      "type": "generated",
      "generator": "join",
      "replaces": "backend-template-webapi",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "projectRootNameKebabCase"
          },
          {
            "type": "const",
            "value": "webapi"
          }
        ],
        "separator": "-",
        "removeEmptyValues": true
      }
    },
    "consumerMetricsJobName": {
      "type": "generated",
      "generator": "join",
      "replaces": "backend-template-consumer",
      "parameters": {
        "symbols": [
          {
            "type": "ref",
            "value": "projectRootNameKebabCase"
          },
          {
            "type": "const",
            "value": "consumer"
          }
        ],
        "separator": "-",
        "removeEmptyValues": true
      }
    }
  },
  "sources": [
    {
      "exclude": [
        ".template.config/**/*",
        ".vs/**/*",
        ".dotnet/**/*",
        "scripts/**/*",
        "**/bin/**/*",
        "**/obj/**/*",
        "**/*.user",
        "**/*.suo"
      ]
    }
  ]
}
