{
  "ConnectionStrings": {
    "PostgresWrite": "Host=localhost;Port=5433;Database=BackendProjectTemplateDb;Username=postgres;Password=postgres;",
    "PostgresRead": "Host=localhost;Port=5433;Database=BackendProjectTemplateDb;Username=postgres;Password=postgres;",
    "Redis": "localhost:6379"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Outbox": {
    "BatchSize": 50,
    "PollIntervalSeconds": 10
  },
  "Authentication": {
    "IpAddressLocationEnrichment": {
      "BatchSize": 50,
      "PollIntervalSeconds": 300,
      "LocationRefreshIntervalDays": 7
    }
  },
  "Jobs": {
    "Payments": {
      "Reconciliation": {
        "BatchSize": 50,
        "PollInterval": "00:00:30",
        "MaxInitiatedAge": "2.00:00:00",
        "StaleThreshold": "00:05:00",
        "RecheckDelay": "00:02:00"
      }
    }
  },
  "IpGeolocation": {
    "IpApiCom": {
      "BaseUrl": "http://ip-api.com"
    },
    "IpInfo": {
      "BaseUrl": "https://ipinfo.io",
      "AccessToken": ""
    },
    "IpWhoIs": {
      "BaseUrl": "https://ipwho.is",
      "ApiKey": ""
    }
  },
  "Messaging": {
    "RabbitMq": {
      "ServiceName": "BackendProjectTemplate.Jobs",
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "EventsExchange": "x.events.backendprojecttemplate",
      "CommandsExchange": "x.commands.backendprojecttemplate"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
