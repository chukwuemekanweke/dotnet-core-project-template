{
  "ConnectionStrings": {
    "PostgresWrite": "Host=localhost;Port=5433;Database=BackendProjectTemplateDb;Username=postgres;Password=postgres;",
    "PostgresRead": "Host=localhost;Port=5433;Database=BackendProjectTemplateDb;Username=postgres;Password=postgres;",
    "Redis": "localhost:6379"
  },
  "Messaging": {
    "RabbitMq": {
      "ServiceName": "BackendProjectTemplate.Consumer",
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "EventsExchange": "x.events.backendprojecttemplate",
      "CommandsExchange": "x.commands.backendprojecttemplate"
    }
  },
  "Authentication": {
    "Lockout": {
      "MaxFailedAttempts": 5,
      "Duration": "12:00:00"
    }
  },
  "Notifications": {
    "Email": {
      "FromAddress": "hello@chidelu.com",
      "FromName": "Backend Project Template",
      "TemplateSetsRootPath": "EmailTemplates/TemplateSets",
      "DefaultBrandKey": "default",
      "BaseTemplateFileName": "BaseTemplate.html",
      "NotificationTemplatesFolder": "NotificationTypes",
      "Mailtrap": {
        "ApiToken": "",
        "UseBulkApi": false,
        "InboxId": null
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "BackendProjectTemplate.Consumer",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
